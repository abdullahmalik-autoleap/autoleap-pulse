# Supabase PostgreSQL (pooled connection for Prisma)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL (direct connection for migrations)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-secret-see-command-above"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# Groq AI
GROQ_API_KEY="gsk_your-key-here"
