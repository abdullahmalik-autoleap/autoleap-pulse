generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @unique
  newSignups      Int
  activeShops     Int
  mrr             Float
  churnRate       Float
  openTickets     Int
  resolvedTickets Int
  trialToPaid     Float
  npsScore        Int
  promoters       Float
  passives        Float
  detractors      Float
  airTrials       Int
  createdAt       DateTime @default(now())
}

model ActivityEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  severity  String   @default("info")
  metadata  String?
  createdAt DateTime @default(now())
}

model FeatureRequest {
  id        String   @id @default(cuid())
  title     String
  votes     Int      @default(0)
  status    String   @default("open")
  createdAt DateTime @default(now())
}

model SignupEvent {
  id          String    @id @default(cuid())
  date        DateTime
  shopName    String
  plan        String
  shopType    String
  region      String
  state       String
  city        String
  source      String
  trialStart  DateTime
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
}

model RevenueSnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique
  mrr               Float
  arr               Float
  newMRR            Float
  expansionMRR      Float
  contractionMRR    Float
  churnMRR          Float
  netNewMRR         Float
  starterRevenue    Float
  proRevenue        Float
  enterpriseRevenue Float
  avgRevenuePerShop Float
  ltv               Float
  paybackPeriod     Float
  createdAt         DateTime @default(now())
}

model ChurnEvent {
  id        String   @id @default(cuid())
  date      DateTime
  shopName  String
  plan      String
  mrrImpact Float
  reason    String
  tenure    Int
  region    String
  createdAt DateTime @default(now())
}

model SupportTicket {
  id              String    @id @default(cuid())
  ticketNumber    String    @unique
  shopName        String
  title           String
  category        String
  status          String    @default("open")
  priority        String    @default("normal")
  channel         String
  assignee        String?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  csat            Int?
  createdAt       DateTime  @default(now())
}

model DailySupportMetric {
  id                  String   @id @default(cuid())
  date                DateTime @unique
  openTickets         Int
  newTickets          Int
  resolvedTickets     Int
  avgFirstResponseMin Int
  avgResolutionHrs    Float
  csatScore           Float
  slaBreaches         Int
  ticketsByCategory   String
  createdAt           DateTime @default(now())
}
